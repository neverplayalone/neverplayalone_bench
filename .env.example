# Copy this file to .env and fill in your values.
# Provider: openrouter (default) or chutes. The matching *_API_KEY is used.
NPABENCH_PROMPT_PROVIDER=openrouter
OPENROUTER_API_KEY=
CHUTES_API_KEY=
# Model id for the chosen provider (e.g. openai/gpt-4.1-mini on OpenRouter).
NPABENCH_PROMPT_MODEL=openai/gpt-4.1-mini
# For Chutes instead (model ids are Hugging-Face style):
# NPABENCH_PROMPT_PROVIDER=chutes
# NPABENCH_PROMPT_MODEL=deepseek-ai/DeepSeek-V3-0324
NPABENCH_PROMPT_TEMPERATURE=0
NPABENCH_PROMPT_MAX_TOKENS=180
NPABENCH_PROMPT_TIMEOUT_SECONDS=8
# Override the endpoint if needed (defaults to the provider's preset base URL).
# NPABENCH_PROMPT_BASE_URL=https://openrouter.ai/api/v1
