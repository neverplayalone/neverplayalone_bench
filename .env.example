# Copy this file to .env and fill in your values.
OPENROUTER_API_KEY=
# OpenRouter-namespaced model id (e.g. openai/gpt-4.1-mini).
NPABENCH_PROMPT_MODEL=openai/gpt-4.1-mini
NPABENCH_PROMPT_TEMPERATURE=0
NPABENCH_PROMPT_MAX_TOKENS=180
NPABENCH_PROMPT_TIMEOUT_SECONDS=8
# Override the OpenRouter endpoint if needed (defaults to https://openrouter.ai/api/v1).
# NPABENCH_PROMPT_BASE_URL=https://openrouter.ai/api/v1
